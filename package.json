{
  "name": "mantine-vite-template",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run oxlint && npm run stylelint",
    "oxlint": "oxlint .",
    "stylelint": "stylelint '**/*.css' --cache",
    "format:test": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\"",
    "vitest": "vitest run",
    "vitest:watch": "vitest",
    "test": "npm run typecheck && npm run format:test && npm run lint && npm run vitest && npm run build",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "start:database": "docker run -d --name pocketbase -p 8090:8090 -v $(pwd)/pb_data:/pb_data -e PB_ADMIN_EMAIL=admin@example.com -e PB_ADMIN_PASSWORD=password ghcr.io/muchobien/pocketbase:latest"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.4.0",
    "@dnd-kit/helpers": "^0.4.0",
    "@dnd-kit/react": "^0.4.0",
    "@mantine/core": "9.0.0",
    "@mantine/form": "^9.0.2",
    "@mantine/hooks": "9.0.0",
    "@mantine/modals": "^9.0.0",
    "@mantine/notifications": "^9.0.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.96.1",
    "pocketbase": "^0.26.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.0.0",
    "@storybook/react": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prop-types": "^15.8.1",
    "storybook": "^10.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.13.0"
}
